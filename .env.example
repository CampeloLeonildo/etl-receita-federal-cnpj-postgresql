# =============================================================================
# CONFIGURAÇÕES DE DIRETÓRIOS
# =============================================================================

# Pasta onde os arquivos .zip baixados da Receita Federal serão salvos.
OUTPUT_FILES_PATH=D:\RFB\Dados_RFB\OUTPUT_FILES

# Pasta onde os arquivos extraídos dos .zip serão armazenados temporariamente.
# Atenção: no seu exemplo está D:\EFB. Confirme se é EFB mesmo ou se deveria ser RFB.
EXTRACTED_FILES_PATH=D:\EFB\Dados_RFB\EXTRACTED_FILES


# =============================================================================
# CONFIGURAÇÕES DO BANCO POSTGRESQL
# =============================================================================

# Host onde o PostgreSQL está rodando.
DB_HOST=localhost

# Porta padrão do PostgreSQL.
DB_PORT=5432

# Usuário do PostgreSQL.
DB_USER=postgres

# Senha do PostgreSQL.
DB_PASSWORD="xxxxxxx"

# Nome do banco de dados.
DB_NAME=RFB


# =============================================================================
# CONFIGURAÇÕES DA ORIGEM DOS DADOS
# =============================================================================

# Link público da Receita Federal contendo os arquivos .zip.
# Altere o mês conforme a pasta que você deseja processar.
PUBLIC_SHARE_URL=https://arquivos.receitafederal.gov.br/index.php/s/YggdBLfdninEJX9?dir=/2026-04


# =============================================================================
# MODO DE EXECUÇÃO DO ETL
# =============================================================================

# Define como o ETL deve iniciar.
#
# FULL:
#   Inicia uma carga nova do zero para a data atual.
#   Apaga as tabelas snapshot da data atual e remove checkpoints da data atual.
#
# RESUME:
#   Continua uma carga interrompida.
#   Não apaga as tabelas snapshot.
#   Pula partes já concluídas com status SUCESSO na tabela public.etl_checkpoint.
#
# RESET:
#   Limpa tabelas snapshot, checkpoints e logs de arquivo da data atual.
#   Depois executa novamente como uma carga nova.
RUN_MODE=FULL


# =============================================================================
# CONFIGURAÇÕES DE TESTE E PERFORMANCE
# =============================================================================

# Limita a quantidade de linhas lidas por parte/arquivo.
#
# Use 0 para carga completa.
# Use um número pequeno para teste, por exemplo 10000.
#
# Para testar:
# LIMIT_ROWS=10000
#
# Para carga completa:
# LIMIT_ROWS=0
LIMIT_ROWS=0

# Quantidade de snapshots que serão mantidos por tabela.
#
# Exemplo:
# KEEP_LAST_SNAPSHOTS=2 mantém o snapshot atual e o snapshot anterior.
# Snapshots mais antigos serão removidos ao final da carga com sucesso.
KEEP_LAST_SNAPSHOTS=2


# =============================================================================
# CONFIGURAÇÃO OPCIONAL
# =============================================================================

# Caminho alternativo para localizar este arquivo .env.
# Normalmente não precisa preencher.
#
# O código já procura por padrão:
# D:\RFB\code\.env
#
# Só use se quiser apontar para outro caminho.
# ENV_FILE_PATH=D:\RFB\code\.env
